generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model employee {
  employee_id    Int              @id
  first_name     String           @db.VarChar(60)
  last_name      String           @db.VarChar(60)
  is_manager     Boolean
  password       Int?
  orders         orders[]
  zreporthistory zreporthistory[]
}

model ingredient {
  id                        Int                         @id @default(autoincrement())
  name                      String                      @unique @db.VarChar(255)
  servings_available        Decimal                     @db.Decimal(12, 2)
  add_cost                  Decimal                     @db.Decimal(10, 2)
  inventoryorder_ingredient inventoryorder_ingredient[]
  itemingredient            itemingredient[]
}

model inventoryorder {
  id                        BigInt                      @id(map: "inventory_order_pkey") @default(autoincrement())
  ordered_at                DateTime                    @default(now()) @db.Timestamptz(6)
  status                    String                      @default("pending") @db.VarChar(20)
  inventoryorder_ingredient inventoryorder_ingredient[]
}

model inventoryorder_ingredient {
  order_id       BigInt
  ingredient_id  Int
  quantity       Int
  unit_cost      Decimal        @db.Decimal(10, 2)
  ingredient     ingredient     @relation(fields: [ingredient_id], references: [id], onUpdate: NoAction)
  inventoryorder inventoryorder @relation(fields: [order_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([order_id, ingredient_id])
}

model item {
  id             Int              @id @default(autoincrement())
  name           String           @db.VarChar(255)
  cost           Decimal          @db.Decimal(10, 2)
  itemingredient itemingredient[]
  orderitem      orderitem[]
}

model itemingredient {
  item_id       Int
  ingredient_id Int
  quantity      Int
  ingredient    ingredient @relation(fields: [ingredient_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  item          item       @relation(fields: [item_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([item_id, ingredient_id])
}

model orderitem {
  order_item_id Int     @id @default(autoincrement())
  order_id      Int
  item_id       Int
  quantity      Int
  sweetness     Int
  ice           Int
  boba          Int
  mango_jelly   Int
  aloe_jelly    Int
  cost          Decimal @db.Decimal(10, 2)
  item          item    @relation(fields: [item_id], references: [id], onUpdate: NoAction)
  orders        orders  @relation(fields: [order_id], references: [order_id], onDelete: Cascade, onUpdate: NoAction)
}

model orders {
  order_id    Int         @id @default(autoincrement())
  employee_id Int
  created_at  DateTime    @db.Timestamp(6)
  cost        Decimal     @db.Decimal(10, 2)
  orderitem   orderitem[]
  employee    employee    @relation(fields: [employee_id], references: [employee_id], onUpdate: NoAction)
}

model test_table {
  thing String? @db.VarChar(100)

  @@ignore
}

model zreporthistory {
  id                       Int       @id @default(autoincrement())
  business_date            DateTime  @unique @db.Date
  generated_at             DateTime  @default(now()) @db.Timestamp(6)
  generated_by_employee_id Int?
  total_sales              Decimal   @db.Decimal(10, 2)
  order_count              Int
  average_order_value      Decimal   @db.Decimal(10, 2)
  employee                 employee? @relation(fields: [generated_by_employee_id], references: [employee_id], onDelete: NoAction, onUpdate: NoAction)
}
